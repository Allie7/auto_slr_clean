# Auto SLR — 环境变量配置
# 复制此文件为 .env 并填入实际值

# ═══════════════════════════════════════════
# LLM API 配置（build_finetune_data.py 使用）
# ═══════════════════════════════════════════
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/
OPENAI_MODEL=deepseek-v4-flash

# 模拟学生 LLM（build_finetune_data.py 使用）
SIMULATOR_API_KEY=your_api_key_here
SIMULATOR_BASE_URL=https://api.deepseek.com/
SIMULATOR_MODEL=deepseek-chat

# ═══════════════════════════════════════════
# CLEF-TAR 2019 数据路径（所有脚本共用）
# ═══════════════════════════════════════════
# 数据目录结构期望：
#   {CLEF_TAR_BASE}/Task1/Training/Intervention/protocols.jsonl
#   {CLEF_TAR_BASE}/Task2/Training/Intervention/papers.jsonl
#   {CLEF_TAR_BASE}/Task2/Training/Intervention/qrels/full.train.int.abs.2019.qrels
#   {CLEF_TAR_BASE}/Task1/Testing/Intervention/protocols.jsonl
#   {CLEF_TAR_BASE}/Task2/Testing/Intervention/papers.jsonl
#   {CLEF_TAR_BASE}/Task2/Testing/Intervention/qrels/full.test.intervention.abs.2019.qrels
CLEF_TAR_BASE=/path/to/2019-TAR

# ═══════════════════════════════════════════
# Qwen2.5-1.5B-Instruct 模型路径
# ═══════════════════════════════════════════
BASE_MODEL_PATH=/path/to/Qwen2.5-1.5B-Instruct

# ═══════════════════════════════════════════
# Semantic Scholar API（可选）
# ═══════════════════════════════════════════
SEMANTIC_SCHOLAR_API_KEY=

# ═══════════════════════════════════════════
# 代理配置（可选）
# ═══════════════════════════════════════════
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
